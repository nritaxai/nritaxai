<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Use a drawable wrapper so Android can center the splash artwork on a solid launch background. -->
        <item name="android:windowBackground">@drawable/launch_splash</item>
        <!-- Match the splash plugin background color during native launch. -->
        <item name="android:windowSplashScreenBackground">#ffffff</item>
        <!-- Use a square mark here because Android 12+ masks the splash icon into a fixed-size slot. -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_mark</item>
        <!-- Show the full NRITAX brand separately so the .AI wordmark stays readable during launch. -->
        <item name="android:windowSplashScreenBrandingImage">@drawable/splash_branding</item>
        <!-- Continue into the normal no-action-bar theme once the launch screen finishes. -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
