{
  "name": "nritax-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "ai-gateway",
    "workers",
    "shared",
    "infrastructure",
    "monitoring"
  ],
  "scripts": {
    "setup": "node ./scripts/setup-workspace.mjs",
    "dev": "node ./scripts/dev-workspace.mjs",
    "dev:api": "npm --prefix server run dev",
    "dev:web": "npm --prefix client run dev",
    "dev:worker": "npm --prefix server run worker",
    "build": "npm --prefix client run build",
    "build:validate": "npm run build && docker build -t nritax-server-ci -f server/Dockerfile server && docker build -t nritax-worker-ci -f server/Dockerfile.worker server",
    "test": "node ./scripts/test-workspace.mjs",
    "test:server": "npm --prefix server run test",
    "lint": "node ./scripts/lint-workspace.mjs",
    "typecheck": "node ./scripts/typecheck-workspace.mjs",
    "ci:verify": "npm run lint && npm run typecheck && npm run test && npm run build:validate"
  },
  "engines": {
    "node": ">=22"
  }
}
